{
  // workbench
  "workbench.colorTheme": "Solarized Light",
  "workbench.preferredLightColorTheme": "Solarized Light",
  "workbench.preferredDarkColorTheme": "One Dark Pro Darker",
  "workbench.iconTheme": "vscode-icons",
  "workbench.startupEditor": "none",
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "type",
  "git.openRepositoryInParentFolders": "never",
  "git.suggestSmartCommit": false,

  // editor
  "editor.fontFamily": "'Source Code Pro', Menlo, Monaco, 'Courier New', monospace",
  "editor.tabSize": 2,
  "editor.renderWhitespace": "boundary",
  "editor.cursorBlinking": "solid",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.copyWithSyntaxHighlighting": false,
  "editor.minimap.enabled": false,
  "editor.lightbulb.enabled": "off",
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.rulers": [ 100 ],
  "files.insertFinalNewline": true,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // This setting is assuming assembly
  "[plaintext]": {
    "editor.insertSpaces": false,
    "editor.tabSize": 8
  },

  "[python]": {
    "editor.tabSize": 4,
    "editor.insertSpaces": true
  },

  "[rust]": {
    "editor.tabSize": 2
  },

  // extensions
  "extensions.ignoreRecommendations": true,

  "cSpell.enabledFileTypes": {
    "json": false
  },
  "cSpell.enabledNotifications": {
    "Average Word Length too Long": false,
    "Maximum Word Length Exceeded": false,
    "Lines too Long": false
  },

  "indentRainbow.includedLanguages": [
    "shellscript",
    "typescript",
    "python",
    "jsonc"
  ],
  "indentRainbow.colorOnWhiteSpaceOnly": true,

  "github.copilot.enable": {
    "*": false
  },
  "github.copilot.nextEditSuggestions.enabled": true,

  "githubPullRequests.createOnPublishBranch": "never",
  "githubPullRequests.fileListLayout": "tree",

  "clangd.arguments": [
    "--header-insertion=never"
  ],

  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.cargo.allTargets": false,

  "markdown-pdf.displayHeaderFooter": false,

  // others
  "zenMode.fullScreen": false,
  "zenMode.centerLayout": false,
  "files.associations": {
    "*.pl": "prolog",
    "*.json": "jsonc",
    "justfile": "text"
  },
  "window.customTitleBarVisibility": "windowed",
  "window.titleBarStyle": "custom",
  "window.zoomLevel": -1,
  "breadcrumbs.enabled": false,
  "terminal.integrated.suggest.enabled": false
}
